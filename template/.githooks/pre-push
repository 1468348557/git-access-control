#!/usr/bin/env bash
# pre-push hook: 仅校验分支命名，不合法则拒绝推送
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BOLD='\033[1m'
NC='\033[0m'

fail() {
  local branch="$1"
  local reason="$2"

  echo ""
  echo -e "${RED}${BOLD}========================================${NC}"
  echo -e "${RED}${BOLD}  推送被拦截 - 分支命名不符合规范${NC}"
  echo -e "${RED}${BOLD}========================================${NC}"
  echo ""
  echo -e "${BOLD}当前分支:${NC} ${YELLOW}${branch}${NC}"
  echo -e "${BOLD}原因:${NC}     ${reason}"
  echo ""
  echo -e "${BOLD}允许的分支格式:${NC}"
  echo ""
  echo "  业务分支 (合入 uat/hotfix/release):"
  echo -e "    ${GREEN}FIX-YYYYMMDD-NNNN${NC}      例如 FIX-20260513-0001"
  echo -e "    ${GREEN}FIX-YYYYMMDD-NNNN-名称${NC}   例如 FIX-20260513-0001-修复登录"
  echo -e "    ${GREEN}REQ-YYYYMMDD-NNNN${NC}      例如 REQ-20260513-0001"
  echo -e "    ${GREEN}REQ-YYYYMMDD-NNNN-名称${NC}   例如 REQ-20260513-0001-用户管理"
  echo -e "    ${GREEN}PUB-YYYYMMDD-NNNN${NC}      例如 PUB-20260513-0001"
  echo -e "    ${GREEN}PUB-YYYYMMDD-NNNN-名称${NC}   例如 PUB-20260513-0001-上线配置"
  echo ""
  echo "  紧急修复 (合入 master):"
  echo -e "    ${GREEN}hotfix-YYYYMMDD${NC}         例如 hotfix-20260513"
  echo ""
  echo "  发布分支 (合入 master):"
  echo -e "    ${GREEN}release-YYYYMMDD${NC}        例如 release-20260513"
  echo ""
  echo "  其他:"
  echo -e "    ${GREEN}comp-*${NC}                  例如 comp-refactor"
  echo -e "    ${GREEN}feature-*${NC}               例如 feature-new-ui"
  echo ""
  echo -e "${BOLD}提示:${NC} 日期部分必须是真实存在的日期(YYYYMMDD)"
  echo -e "${BOLD}修改分支名:${NC} git branch -m ${branch} FIX-$(date +%Y%m%d)-0001"
  echo ""
  exit 1
}

BRANCH_PATTERN='^((FIX|REQ|PUB)-[0-9]{8}-[0-9]{4}(-.+)?|(hotfix|release)-[0-9]{8}|comp-|feature-)'

check_date_valid() {
  local date_part="$1"
  local formatted_date
  if ! formatted_date=$(date -d "$date_part" +"%Y%m%d" 2>/dev/null); then
    return 1
  fi
  [[ "$formatted_date" == "$date_part" ]]
}

while read -r local_ref local_sha remote_ref remote_sha; do
  branch="$(git rev-parse --abbrev-ref HEAD)"

  if [[ ! "$branch" =~ $BRANCH_PATTERN ]]; then
    fail "$branch" "分支名不符合任何允许的格式"
  fi

  local date_part=""
  if [[ "$branch" =~ ^(FIX|REQ|PUB)-[0-9]{8}-[0-9]{4} ]] || \
     [[ "$branch" =~ ^(hotfix|release)-[0-9]{8} ]]; then
    date_part="$(echo "$branch" | awk -F- '{print $2}')"
  fi

  if [[ -n "$date_part" ]]; then
    if ! check_date_valid "$date_part"; then
      fail "$branch" "日期 ${date_part} 不是真实日期，或格式非 YYYYMMDD"
    fi
  fi

  echo -e "${GREEN}[pre-push] 分支命名校验通过${NC}"
done

exit 0
